# =============================================================================
# AI Sales Coach — Kraft Heinz China
# Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="AI Sales Coach"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_sales_coach"

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL=http://localhost:3000/api/auth

# -----------------------------------------------------------------------------
# AI / LLM Providers
# -----------------------------------------------------------------------------

# === Qwen (DashScope) ===
# Supports: Text + Vision (VL) for menu image recognition
# Get API key: https://dashscope.console.aliyun.com/
QWEN_API_KEY="your-qwen-api-key-here"
QWEN_MODEL="qwen-vl-max"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# === DeepSeek ===
# Supports: Text only (no vision capability)
# Get API key: https://platform.deepseek.com/
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# === Default LLM Provider ===
# Options: "qwen" | "deepseek"
DEFAULT_LLM_PROVIDER="qwen"

# -----------------------------------------------------------------------------
# Vector Database (for RAG - Knowledge Base)
# -----------------------------------------------------------------------------

# Option 1: pgvector (PostgreSQL extension)
# Using same DATABASE_URL as above with pgvector extension

# Option 2: Pinecone (if needed)
# PINECONE_API_KEY="your-pinecone-api-key"
# PINECONE_INDEX="ai-sales-coach"

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
# For menu image uploads
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="10485760"  # 10MB

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
NODE_ENV="development"
